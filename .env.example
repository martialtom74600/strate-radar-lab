# Copier ce fichier en .env et renseigner les valeurs.

# ---------------------------------------------------------------------------
# Mode simulation (dry run) — pas d’appels Places / PageSpeed / Groq
# true | 1 | yes → données fictives uniquement
# false ou absent → appels réels (clés requises selon les étapes utilisées)
# ---------------------------------------------------------------------------
STRATE_RADAR_SIMULATION=false

# Google Cloud — Places API (Text Search)
# Console : https://console.cloud.google.com/apis/library/places.googleapis.com
# Créer une clé API avec "Places API" activée ; facturation requise pour les crédits mensuels.
GOOGLE_PLACES_API_KEY=

# @deprecated — ancien fournisseur SerpApi (simulation / scripts uniquement si besoin)
# SERPAPI_API_KEY=

# Google PageSpeed Insights API
# https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=

# Groq (Llama 3 — analyse IA)
# https://console.groq.com/keys
GROQ_API_KEY=

# Optionnel : modèle Groq (défaut géré dans le code si vide)
GROQ_MODEL=llama-3.3-70b-versatile

# Limites de concurrence (requêtes parallèles par fournisseur)
SERPAPI_CONCURRENCY=3
PAGESPEED_CONCURRENCY=2

# Base SQLite (chemin relatif au répertoire de travail)
# Sur GitHub Actions, ce fichier est versionné (défaut data/strate-radar.sqlite) pour garder la mémoire entre les runs.
STRATE_RADAR_DB_PATH=data/strate-radar.sqlite

# Texte de recherche par défaut (pipeline matinal)
RADAR_SEARCH_Q=boulangerie artisanale
# Zone : libellé lisible pour la requête Text Search (ex. "Ville, Pays").
RADAR_SEARCH_LOCATION=Annecy, France

# Liste de grainage multi-métiers (recommandé) — enchaîne les familles jusqu’aux 5 Diamants
# true | 1 | yes (défaut) — false pour une seule requête RADAR_SEARCH_Q
# RADAR_USE_SEED_LIST=true

# Plafond d’appels Places Text Search par run (pack local + résolution site ; garde-fou interne)
# RADAR_MAX_SERPAPI_REQUESTS=150

# Ne pas retraiter un lieu déjà vu en diamant / disqualifié sur les N derniers jours
# RADAR_SQLITE_RECENT_DAYS=7

# Export JSON pour maquettes « shadow site »
# RADAR_SHADOW_EXPORT_PATH=data/shadow-sites-export.json

# Journal en direct dans le terminal (familles, pages Places, chaque fiche)
# true par défaut — mettre false pour sortie minimale (scripts / cron)
# RADAR_VERBOSE=true

# Timeout fetch HTML pour la matrice Strate (ms, défaut 15000)
# RADAR_FETCH_TIMEOUT_MS=15000

# Prospection pilotée par intentions Google Suggest (gratuit) — remplace le grainage statique
# RADAR_TREND_DRIVEN=true
# Revenir au grainage DIAMOND_SEED_CATEGORIES + ville : RADAR_TREND_DRIVEN=false
# RADAR_USE_SEED_LIST=true

# Génération automatique des HTML « Shadow Pages » après export JSON
# RADAR_AUTO_GENERATE_SHADOW_PAGES=true
# RADAR_SHADOW_PAGES_DIR=data/shadow-pages

# Rapport Markdown généré en fin de run
RADAR_REPORT_PATH=rapport_matinal.md

# Diamond Hunter — objectif de profils « Diamant » par run (pagination Places jusqu’à concurrence ou max pages)
# RADAR_TARGET_DIAMOND_COUNT=5
# Max pages Text Search par intention (~20 résultats/page)
# RADAR_SERP_MAX_PAGES=3
# Virgules : sous-chaînes pour filtrer la zone (adresse / titre Maps), ex. annecy,chambéry
# RADAR_DIAMOND_LOCATION_HINTS=annecy,chambéry

# Optionnel : domaine Google (mocks / compat ; Places utilise hl/gl côté API)
# SERPAPI_GOOGLE_DOMAIN=google.fr

# Environnement Node
NODE_ENV=development
