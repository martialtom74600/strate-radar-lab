# Copier ce fichier vers `.env` puis renseigner les clés.
# Minimum pour `npm run scrub` (mode réel) :
GOOGLE_PLACES_API_KEY=

# Source audits publiés Supabase — chargée auto depuis mon-site/.env.local si présente :
# DATABASE_URL=postgresql://...

# Recherche web couche 4 (website-resolver) — Serper en priorité, Brave en fallback :
# SERPER_API_KEY=
# BRAVE_SEARCH_API_KEY=

# Optionnel — simulation sans appels API (dry-run auto si clé Places absente)
# STRATE_RADAR_SIMULATION=true

# Pipeline radar complet (npm run dev) :
# GOOGLE_PAGESPEED_API_KEY=
# GROQ_API_KEY=
# RADAR_INGEST_SECRET=

# Zone de prospection (défaut : Annecy, France)
# RADAR_SEARCH_LOCATION=Annecy, France
