{
  "name": "strate-radar",
  "version": "0.1.0",
  "private": true,
  "description": "Strate Radar — sourcing local, audit PageSpeed, analyse IA (pipeline modulaire)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "audit:one": "tsx src/scripts/audit-one.ts",
    "telegram:report": "tsx src/scripts/send-telegram-report.ts",
    "generate:shadows": "tsx src/pipeline/generate-shadow-pages.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test 'src/**/*.test.ts' 'src/lib/**/*.test.ts' 'src/lib/ai/**/*.test.ts'",
    "scrub": "tsx src/scripts/retroactive-scrub.ts",
    "revert-scrub": "tsx src/scripts/revert-scrub.ts",
    "serp-classifier:dry-run": "tsx src/scripts/serp-classifier-dry-run.ts",
    "scrub:export-reasons": "tsx src/scripts/export-scrub-reasons.ts",
    "scrub:reasons": "tsx src/scripts/list-scrub-reasons.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "groq-sdk": "^0.15.0",
    "postgres": "^3.4.5",
    "sqlite3": "^5.1.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
